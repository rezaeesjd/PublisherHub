{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rezaeesjd/PublisherHub/structures/intake-form.schema.json",
  "title": "Tour intake form",
  "description": "Structured intake schema for WPS:GENERATE_CONTENT_FROM_INTAKE. Fields whose absence is blocking are listed under `required`. The companion text form is templates/intake-form-template.md.",
  "type": "object",
  "required": [
    "active_brand",
    "canonical_tour_title",
    "product_reference_code",
    "website_link",
    "meeting_point",
    "end_point",
    "duration",
    "start_time",
    "departure_days",
    "group_type",
    "languages",
    "hotel_pickup_dropoff",
    "inclusions",
    "currency",
    "pricing_model",
    "cancellation_window",
    "confirmation"
  ],
  "additionalProperties": true,
  "properties": {
    "active_brand": {
      "type": "string",
      "minLength": 1,
      "description": "System brand for all public copy. Default: Milano Adventures."
    },
    "raw_supplier_name": {
      "type": ["string", "null"],
      "description": "Recorded only in source-facts.md, never used as the public brand."
    },
    "canonical_tour_title": { "type": "string", "minLength": 1 },
    "product_reference_code": { "type": ["string", "number"] },
    "channel_product_codes": {
      "type": "object",
      "additionalProperties": { "type": ["string", "number"] },
      "description": "Channel-specific product codes (e.g. {\"viator\": \"187808P82\"})."
    },
    "website_link": {
      "type": "string",
      "format": "uri",
      "description": "Direct website booking URL. Conversion blocker if missing."
    },
    "tripadvisor_link": { "type": ["string", "null"], "format": "uri" },
    "viator_link": { "type": ["string", "null"], "format": "uri" },
    "other_ota_links": {
      "type": "object",
      "additionalProperties": { "type": "string", "format": "uri" }
    },
    "meeting_point": { "type": "string", "minLength": 1 },
    "meeting_point_details": { "type": ["string", "null"] },
    "end_point": { "type": "string", "minLength": 1 },
    "same_as_meeting_point": { "type": "boolean" },
    "duration": { "type": "string", "minLength": 1 },
    "start_time": { "type": "string", "pattern": "^[0-2][0-9]:[0-5][0-9]$" },
    "departure_days": {
      "type": "array",
      "items": { "type": "string", "enum": ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"] },
      "minItems": 1,
      "uniqueItems": true
    },
    "group_type": { "type": "string", "enum": ["Shared", "Private"] },
    "max_travelers": { "type": ["integer", "null"], "minimum": 1 },
    "min_travelers_to_operate": { "type": ["integer", "null"], "minimum": 0 },
    "difficulty": { "type": ["string", "null"], "enum": ["Easy", "Moderate", "Challenging", null] },
    "languages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "format": { "type": "string", "enum": ["live", "audio", "written"] }
        }
      },
      "minItems": 1
    },
    "hotel_pickup_dropoff": {
      "type": "string",
      "enum": ["included", "not_included", "optional_addon"]
    },
    "wheelchair_accessibility": {
      "type": ["string", "null"],
      "enum": ["accessible", "not_accessible", "partial", null]
    },
    "stops": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "duration_minutes": { "type": ["integer", "null"], "minimum": 0 }
        }
      }
    },
    "visit_order_may_vary": { "type": "boolean" },
    "inclusions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "exclusions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "pricing_model": { "type": "string", "enum": ["per_person", "per_group", "per_booking"] },
    "pricing_valid_from": { "type": ["string", "null"], "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "age_bands": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "pricing": {
      "type": "object",
      "additionalProperties": { "type": "number", "minimum": 0 }
    },
    "cancellation_window": {
      "type": "object",
      "required": ["amount", "unit"],
      "properties": {
        "amount": { "type": "integer", "minimum": 0 },
        "unit": { "type": "string", "enum": ["hours", "days"] }
      }
    },
    "confirmation": { "type": "string", "enum": ["instant", "manual"] },
    "ticket_format": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tickets_per_booking": { "type": ["integer", "null"], "minimum": 1 },
    "booking_info_required": {
      "type": "array",
      "items": { "type": "string" }
    },
    "seasonal_components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["component", "note"],
        "properties": {
          "component": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    },
    "review_data": {
      "type": ["object", "null"],
      "properties": {
        "rating": { "type": ["number", "null"] },
        "count": { "type": ["integer", "null"] },
        "source": { "type": ["string", "null"], "format": "uri" },
        "quotes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["text", "source"],
            "properties": {
              "text": { "type": "string" },
              "source": { "type": "string" },
              "author": { "type": ["string", "null"] }
            }
          }
        }
      }
    },
    "destination_context": {
      "type": "object",
      "properties": {
        "heritage_status": { "type": ["string", "null"] },
        "region": { "type": ["string", "null"] },
        "named_landmarks": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "provisional_mode": {
      "type": "boolean",
      "description": "When true, generation proceeds despite blocking clarifications and public_copy_state is set to 'provisional'. Must be set explicitly by the user."
    },
    "funnel_stage_override": {
      "type": ["string", "null"],
      "enum": ["TOFU", "MOFU", "BOFU", null]
    }
  }
}
