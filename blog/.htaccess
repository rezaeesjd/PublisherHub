# WebPublisherSystem public blog — clean URLs, robots.txt, llms.txt, sitemap.
# Designed for Apache 2.4 with mod_rewrite. No-ops on hosts without mod_rewrite.

<IfModule mod_rewrite.c>
    RewriteEngine On

    # /blog/robots.txt -> robots.txt.php
    RewriteRule ^robots\.txt$ robots.txt.php [L]

    # /blog/llms.txt -> llms.txt.php
    RewriteRule ^llms\.txt$ llms.txt.php [L]

    # /blog/sitemap.xml -> sitemap.xml.php
    RewriteRule ^sitemap\.xml$ sitemap.xml.php [L]

    # Clean post URLs: /blog/post/<slug> -> post.php?slug=<slug>
    RewriteRule ^post/([A-Za-z0-9_-]+)/?$ post.php?slug=$1 [QSA,L]

    # Clean pagination: /blog/page/<n> -> index.php?page=<n>
    RewriteRule ^page/([0-9]+)/?$ index.php?page=$1 [QSA,L]
</IfModule>

# Compression — small but cumulative win for HTML/CSS/JSON-LD payloads.
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml text/javascript application/javascript application/json application/ld+json application/xml image/svg+xml
</IfModule>

# Cache headers for static assets (PHP-rendered HTML is not cached here).
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType image/avif "access plus 30 days"
    ExpiresByType image/svg+xml "access plus 30 days"
</IfModule>
