{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rezaeesjd/PublisherHub/content-system/structures/intake-form.schema.json",
  "title": "WPS tour intake form",
  "type": "object",
  "required": [
    "canonical_tour_title",
    "active_brand",
    "product_reference_code",
    "website_link",
    "meeting_point",
    "duration",
    "start_time",
    "languages",
    "cancellation_window",
    "pricing"
  ],
  "properties": {
    "canonical_tour_title": {"type":"string","minLength":1},
    "active_brand": {"type":"string","minLength":1},
    "product_reference_code": {"type":"string","minLength":1},
    "channel_product_codes": {"type":"object","additionalProperties":{"type":"string"}},
    "website_link": {"type":"string","minLength":1},
    "tripadvisor_link": {"type":"string"},
    "viator_link": {"type":"string"},
    "meeting_point": {"type":"string","minLength":1},
    "end_point": {"type":"string"},
    "duration": {"type":"string","minLength":1},
    "start_time": {"type":"string","pattern":"^[0-2][0-9]:[0-5][0-9]$"},
    "languages": {"type":"array","minItems":1,"items":{"type":"string"}},
    "cancellation_window": {
      "type":"object",
      "required":["value","unit"],
      "properties":{
        "value":{"type":"integer","minimum":0},
        "unit":{"type":"string","enum":["hours","days"]}
      }
    },
    "pricing": {"type":"object","minProperties":1,"additionalProperties":{"type":"number","minimum":0}}
  },
  "additionalProperties": true
}
