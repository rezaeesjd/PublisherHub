{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rezaeesjd/PublisherHub/content-system/meta.schema.json",
  "title": "Tour package meta.json",
  "description": "Schema for content-system/tours/<slug>/meta.json. Validated by platform/qa-rules.php.",
  "type": "object",
  "required": [
    "brand",
    "canonical_tour_title",
    "page_title",
    "slug",
    "public_slug",
    "meta_description",
    "primary_keyword",
    "funnel_stage",
    "cta_primary",
    "cta_primary_link",
    "website_link",
    "publish_status",
    "human_review_required",
    "qa_status"
  ],
  "additionalProperties": true,
  "properties": {
    "brand": {
      "type": "string",
      "minLength": 1,
      "description": "Active brand used in all public copy."
    },
    "product_reference_code": { "type": ["string", "number"] },
    "secondary_product_codes": {
      "type": "object",
      "additionalProperties": { "type": ["string", "number"] }
    },
    "canonical_tour_title": { "type": "string", "minLength": 1 },
    "tour_title": { "type": "string", "minLength": 1 },
    "page_title": { "type": "string", "minLength": 1, "maxLength": 120 },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
    },
    "public_slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
    },
    "meta_description": { "type": "string", "minLength": 50, "maxLength": 200 },
    "primary_keyword": { "type": "string", "minLength": 1 },
    "funnel_stage": { "type": "string", "enum": ["TOFU", "MOFU", "BOFU"] },
    "cta_primary": { "type": "string", "minLength": 1 },
    "cta_primary_link": { "type": "string", "minLength": 1 },
    "website_link": { "type": "string", "minLength": 1 },
    "tripadvisor_link": { "type": "string" },
    "viator_link": { "type": "string" },
    "cta_secondary_links": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "meeting_point": { "type": "string" },
    "meeting_point_details": { "type": "string" },
    "end_point": { "type": "string" },
    "duration": { "type": "string" },
    "start_time": { "type": "string", "pattern": "^[0-2][0-9]:[0-5][0-9]$" },
    "departure_days": {
      "type": "array",
      "items": { "type": "string", "enum": ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"] },
      "uniqueItems": true
    },
    "group_type": { "type": "string" },
    "max_travelers": { "type": "integer", "minimum": 1 },
    "min_travelers_to_operate": { "type": "integer", "minimum": 0 },
    "difficulty": { "type": "string", "enum": ["Easy", "Moderate", "Challenging"] },
    "languages": { "type": "array", "items": { "type": "string" } },
    "language_formats": { "type": "array", "items": { "type": "string" } },
    "audio_guide": { "type": "boolean" },
    "guide": { "type": "string" },
    "round_trip": { "type": "boolean" },
    "not_private": { "type": "boolean" },
    "wheelchair_accessible": { "type": "boolean" },
    "hotel_pickup_dropoff": { "type": "boolean" },
    "near_public_transportation": { "type": "boolean" },
    "infant_policy": { "type": "string" },
    "age_bands": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "pricing_model": { "type": "string", "enum": ["per_person", "per_group", "per_booking"] },
    "pricing": {
      "type": "object",
      "description": "Per-band pricing keyed by band name (adult, child, infant, etc.)",
      "additionalProperties": { "type": "number", "minimum": 0 }
    },
    "pricing_eur": {
      "type": "object",
      "additionalProperties": { "type": "number", "minimum": 0 }
    },
    "pricing_valid_from": { "type": ["string", "null"] },
    "confirmation": { "type": "string", "enum": ["instant", "manual"] },
    "ticket_format": { "type": "array", "items": { "type": "string" } },
    "tickets_per_booking": { "type": "integer", "minimum": 1 },
    "entry_method": { "type": "string" },
    "cancellation_window_hours": {
      "type": ["integer", "null"],
      "minimum": 0,
      "description": "Cancellation window in hours. Null when the source-supplied unit is unresolved (raw value preserved in cancellation_window_raw and a clarification is open)."
    },
    "cancellation_window_raw": { "type": "string" },
    "categories": { "type": "array", "items": { "type": "string" } },
    "land_transport": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "array", "items": { "type": "string" } },
    "hero_image": {
      "type": "string",
      "description": "Relative path to hero image, e.g. images/hero.jpg, or absolute URL."
    },
    "image_gallery": {
      "type": "array",
      "items": { "type": "string" }
    },
    "publish_status": {
      "type": "string",
      "enum": [
        "draft",
        "ready_for_review",
        "needs_fix",
        "ready_for_sync",
        "needs_live_verification",
        "published",
        "approved",
        "archived"
      ]
    },
    "human_review_required": { "type": "boolean" },
    "qa_status": { "type": "string", "enum": ["pending", "passing", "warning", "needs_fix", "needs_clarification"] },
    "public_copy_state": {
      "type": "string",
      "enum": ["not_started", "holding_notice", "provisional", "final"],
      "description": "Tracks whether the public-facing blog-post.md is a holding notice (hard clarify gate active), a provisionally-approved draft, or final ready-for-review copy."
    },
    "intake_questions_resolved": {
      "type": "boolean",
      "description": "True when the upfront WPS:CLARIFY intake questions have been answered by the user (or explicitly waived via provisional mode)."
    },
    "last_qa_date": { "type": ["string", "null"], "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "clarifications_needed": {
      "type": "array",
      "description": "Open WPS:CLARIFY items written by the generator and resolved by the user.",
      "items": {
        "type": "object",
        "required": ["field", "raw_value", "question"],
        "properties": {
          "field": { "type": "string" },
          "raw_value": {},
          "question": { "type": "string" },
          "blocking": { "type": "boolean", "default": true }
        }
      }
    }
  }
}
